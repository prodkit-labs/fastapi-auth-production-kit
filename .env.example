AUTH_ENV=local
# Used by the default SQLite app routes.
AUTH_DATABASE_PATH=./prodkit-auth.sqlite3
# Required only when intentionally running the default SQLite routes in production.
AUTH_ALLOW_SQLITE_IN_PRODUCTION=false
AUTH_SECRET_KEY=change-me-before-production
AUTH_ACCESS_TOKEN_MINUTES=30
AUTH_PASSWORD_RESET_TOKEN_MINUTES=15
AUTH_EXPOSE_RESET_TOKEN=true
AUTH_EMAIL_VERIFICATION_TOKEN_MINUTES=1440
AUTH_EXPOSE_EMAIL_VERIFICATION_TOKEN=true
AUTH_REQUIRE_VERIFIED_EMAIL_FOR_LOGIN=false
AUTH_LOCAL_RATE_LIMITS=false
AUTH_ACTION_TOKEN_MODE=jwt
AUTH_REGISTRATION_ENUMERATION_MODE=explicit
# Used by the optional SQLAlchemy/Postgres track, not by the default app routes yet.
AUTH_DATABASE_URL=sqlite+pysqlite:///./prodkit-auth.sqlite3
